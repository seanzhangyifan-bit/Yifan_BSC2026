{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Analyze image",
      "type": "debugpy",
      "request": "launch",
      "module": "src.analyze_image",
      "args": ["${input:imagePath}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Analyze image (full diagnostics)",
      "type": "debugpy",
      "request": "launch",
      "module": "src.analyze_image",
      "args": ["${input:imagePath}", "--show-fit-detail"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ],
  "inputs": [
    {
      "id": "imagePath",
      "type": "promptString",
      "description": "Path to the image to analyze (e.g. data/raw/T5/T5-M_H95_v1_mm000001.jpg)"
    }
  ]
}
